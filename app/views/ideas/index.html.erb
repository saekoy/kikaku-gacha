<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">

    <%# ヘッダーセクション %>
    <div class="md:flex md:items-center md:justify-between mb-10 border-b border-gray-200 pb-6">
      <div class="flex-1 min-w-0">
        <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
          配信ネタ・ガチャ <span class="text-indigo-600 text-lg block md:inline md:ml-2">#来週の配信予定</span>
        </h1>
        <p class="mt-2 text-sm text-gray-500">
          今のあなたにぴったりの配信企画を、1週間分ランダムに提案します。
        </p>
      </div>

      <div class="mt-4 flex md:mt-0 md:ml-4 gap-3">
        <%= button_to weekly_schedules_path, 
                      method: :post, 
                      data: { disable_with: "🪄 シャッフル中..." },
                      class: "inline-flex items-center px-8 py-4 border border-transparent rounded-full shadow-lg text-lg font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 transition-all transform hover:scale-105 active:scale-95 disabled:opacity-50" do %>
          ✨ ガチャを回す
        <% end %>
      </div>
    </div>

    <%# メインのグリッドレイアウト %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

      <%# @ideas (DBから取得したデータ) をループさせる %>
      <% @ideas.each_with_index do |idea, index| %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 hover:shadow-lg transition-all duration-500 p-5 flex flex-col h-full relative overflow-hidden animate-in fade-in slide-in-from-bottom-8 fill-mode-both" style="animation-delay: <%= index * 100 %>ms">

          <%# インデックス（0〜6）を使って「何日目」か表示 %>
          <div class="absolute top-0 right-0 bg-indigo-500 text-white px-4 py-1 rounded-bl-xl font-bold text-xs">
            <%= index + 1 %>日目
          </div>

          <div class="flex items-center space-x-2 mb-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
              <%= idea.category %>
            </span>
            <div class="flex text-yellow-400 text-xs">
              <% idea.difficulty.times do %>
                <span>★</span>
              <% end %>
              <% (5 - idea.difficulty).times do %>
                <span class="text-gray-200">★</span>
              <% end %>
            </div>
          </div>

          <h3 class="text-lg font-bold text-gray-900 mb-2 leading-tight">
            <%= idea.title %>
          </h3>

          <p class="text-gray-600 text-sm flex-grow">
            <%= idea.description %>
          </p>

          <div class="mt-4 pt-4 border-t border-gray-100 flex justify-end items-center text-xs">
            <button class="text-indigo-600 hover:underline font-medium">詳細を見る</button>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>