<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">

    <%# ヘッダーセクション：PCでは横並び、スマホでは縦並び %>
    <div class="md:flex md:items-center md:justify-between mb-10 border-b border-gray-200 pb-6">
      <div class="flex-1 min-w-0">
        <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl sm:truncate">
          配信ネタ・ガチャ <span class="text-indigo-600 text-lg block md:inline md:ml-2">#来週の配信予定</span>
        </h1>
        <p class="mt-2 text-sm text-gray-500">
          今のあなたにぴったりの配信企画を、1週間分ランダムに提案します。
        </p>
      </div>
      
      <div class="mt-4 flex md:mt-0 md:ml-4 gap-3">
        <button class="inline-flex items-center px-6 py-3 border border-transparent rounded-full shadow-sm text-base font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all transform hover:scale-105">
          ✨ ガチャを回す
        </button>
        <button class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-full shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
          共有する
        </button>
      </div>
    </div>

    <%# メインコンテンツ：レスポンシブなグリッドレイアウト %>
    <%# grid-cols-1 (スマホ1列), sm:grid-cols-2 (タブレット2列), lg:grid-cols-3 (PC3列), xl:grid-cols-4 (大画面4列) %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

      <%# 月曜日のカード（月曜〜日曜まで繰り返し想定） %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 hover:shadow-lg transition-shadow duration-300 p-5 flex flex-col h-full relative overflow-hidden">
        <%# 曜日のラベル %>
        <div class="absolute top-0 right-0 bg-indigo-600 text-white px-4 py-1 rounded-bl-xl font-bold text-xs">
          MONDAY
        </div>

        <div class="flex items-center space-x-2 mb-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            雑談
          </span>
          <div class="flex text-yellow-400 text-xs">
            <span>★</span><span>★</span><span>★</span><span>☆</span><span>☆</span>
          </div>
        </div>

        <h3 class="text-lg font-bold text-gray-900 mb-2 leading-tight">
          100の質問に答えるまで終われません！
        </h3>

        <p class="text-gray-600 text-sm flex-grow">
          リスナーさんから募集した「100の質問」にひたすら答えていく耐久配信。
        </p>

        <div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center text-xs text-gray-400">
          <span>準備時間：15分</span>
          <button class="text-indigo-600 hover:underline font-medium">詳細を見る</button>
        </div>
      </div>

      <%# 火曜日のカード（サンプルのためもう1枚） %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 hover:shadow-lg transition-shadow duration-300 p-5 flex flex-col h-full relative overflow-hidden opacity-80">
        <div class="absolute top-0 right-0 bg-gray-400 text-white px-4 py-1 rounded-bl-xl font-bold text-xs">
          TUESDAY
        </div>

        <div class="flex items-center space-x-2 mb-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            ゲーム
          </span>
          <div class="flex text-yellow-400 text-xs">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>☆</span>
          </div>
        </div>

        <h3 class="text-lg font-bold text-gray-900 mb-2 leading-tight">
          【初見歓迎】激ムズ死にゲー実況プレイ
        </h3>

        <p class="text-gray-600 text-sm flex-grow">
          話題の新作を、リスナーさんのアドバイスを聞きながら攻略。
        </p>

        <div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center text-xs text-gray-400">
          <span>準備時間：5分</span>
          <button class="text-indigo-600 hover:underline font-medium">詳細を見る</button>
        </div>
      </div>

      <%# 追加のカード（ここにさらに5日分入るイメージ） %>

    </div>

    <%# PCのみ：フッターにTipsを表示 %>
    <div class="mt-12 hidden md:block text-center text-gray-400 text-sm italic">
      Tip: 「共有する」ボタンから、画像付きでXに投稿できます（開発中）
    </div>

  </div>
</div>